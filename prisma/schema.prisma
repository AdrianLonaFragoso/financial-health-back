generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Month {
  id       String   @id @default(cuid())
  label    String
  year     Int
  month    Int
  ingresos Ingreso[]
  gastos   Gasto[]
  exclusiones GastoExclusion[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model GastoExclusion {
  id       String @id @default(cuid())
  monthId  String @map("month_id")
  month    Month  @relation(fields: [monthId], references: [id], onDelete: Cascade)
  concepto String

  @@map("gasto_exclusiones")
}

model Ingreso {
  id       String @id @default(uuid())
  concepto String
  monto    Float
  monthId  String @map("month_id")
  month    Month  @relation(fields: [monthId], references: [id], onDelete: Cascade)
}

model Gasto {
  id        String @id @default(uuid())
  concepto  String
  monto     Float
  categoria String
  fin       String
  monthId   String @map("month_id")
  month     Month  @relation(fields: [monthId], references: [id], onDelete: Cascade)
}

model Credito {
  id                 String   @id @default(uuid())
  tipo               String
  nombre             String
  logoUrl            String?
  lineaCredito       Float
  saldoUtilizado     Float
  tasaInteresMensual Float
  usuario            String
  pagoMensual        Float?
  pagosRealizados    Float?
  pagosCompletados   Int?
  pagosTotales       Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
